{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "in_progress"]
    },
    "summary": {
      "type": "string"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_decisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quality_gates": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "queue_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["open", "in_progress", "completed", "blocked"]
          }
        },
        "required": ["id", "status"]
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": ["path", "description"]
      }
    }
  },
  "required": [
    "task_id",
    "status",
    "summary",
    "notes",
    "blockers",
    "open_decisions",
    "next_actions",
    "quality_gates",
    "queue_updates",
    "artifacts"
  ]
}
